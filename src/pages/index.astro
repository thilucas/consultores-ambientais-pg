---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import RioDivisor from '../components/RioDivisor.astro';
import logo from '../assets/logo.png';

const empresas = (await getCollection('empresas')).sort(
  (a, b) => a.data.ordem - b.data.ordem || a.data.nome.localeCompare(b.data.nome, 'pt-BR')
);

const eventos = (await getCollection('eventos')).sort(
  (a, b) => b.data.data.valueOf() - a.data.data.valueOf()
);

const formatarData = (d: Date) =>
  d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' });

const resumo = (corpo: string | undefined, max = 150) => {
  const texto = (corpo ?? '')
    .replace(/[#>*_`\[\]()!-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  return texto.length > max ? texto.slice(0, max).replace(/\S+$/, '') + '…' : texto;
};

const valores = [
  'Ética e transparência',
  'Excelência técnica',
  'Associativismo e cooperação',
  'Sustentabilidade',
  'Valorização profissional',
];

const atuacao = [
  { titulo: 'Parcerias', texto: 'Conexões entre empresas, poder público e instituições do setor.' },
  { titulo: 'Aprendizados', texto: 'Capacitações e troca de experiências técnicas entre associados.' },
  { titulo: 'Oportunidades', texto: 'Acesso ampliado a projetos, editais e demandas do mercado.' },
  { titulo: 'Visibilidade', texto: 'Divulgação do trabalho das empresas associadas na região.' },
  { titulo: 'Network', texto: 'Uma rede ativa de profissionais da gestão ambiental.' },
  { titulo: 'Destaque no mercado', texto: 'O selo de uma classe organizada, ética e qualificada.' },
  { titulo: 'Facilitação', texto: 'Um meio facilitador da missão empresarial de cada associado.' },
];
---

<Base
  title="Associação dos Consultores Ambientais de Ponta Grossa"
  description="Empresas conectadas, ambiente preservado, Ponta Grossa protegida. Associação de consultores e empresas de gestão ambiental de Ponta Grossa – PR, vinculada à ACIPG."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero" aria-labelledby="titulo-hero">
    <div class="container hero-grid">
      <div class="hero-texto">
        <p class="eyebrow reveal" style="--i:0">Ponta Grossa – PR · fundada em 10/12/2025</p>
        <h1 id="titulo-hero" class="reveal" style="--i:1">
          Empresas <em>conectadas</em>, ambiente <em>preservado</em>, Ponta&nbsp;Grossa <em>protegida</em>.
        </h1>
        <p class="hero-sub reveal" style="--i:2">
          Somos a associação que reúne consultores e empresas de gestão ambiental dos Campos
          Gerais para fortalecer o setor, padronizar práticas e promover o desenvolvimento
          sustentável.
        </p>
        <div class="hero-acoes reveal" style="--i:3">
          <a class="btn btn-solid" href="#empresas">Conheça as empresas</a>
          <a class="btn btn-ghost" href="#contato">Fale conosco</a>
        </div>
      </div>
      <div class="hero-logo reveal" style="--i:2">
        <Image src={logo} alt="Logotipo da Associação dos Consultores Ambientais de Ponta Grossa: araucária, folhas, rio e cidade dentro de um círculo" width={480} loading="eager" />
      </div>
    </div>
  </section>

  <RioDivisor />

  <!-- ===================== SOBRE ===================== -->
  <section id="sobre" aria-labelledby="titulo-sobre">
    <div class="container">
      <p class="eyebrow reveal" style="--i:0">Sobre a Associação</p>
      <h2 id="titulo-sobre" class="section-title reveal" style="--i:1">Uma classe organizada em torno do meio ambiente</h2>
      <div class="sobre-grid">
        <div class="sobre-texto reveal reveal-soft" style="--i:2">
          <p>
            O associativismo em gestão ambiental une profissionais e empresas para fortalecer o
            setor, padronizar práticas e influenciar políticas públicas. Em Ponta Grossa, a
            <strong>ACIPG</strong> atua como o principal polo dessa articulação, abrigando a
            Associação dos Consultores Ambientais e oferecendo capacitações para o
            desenvolvimento sustentável local.
          </p>
          <p>
            Criada em <strong>10 de dezembro de 2025</strong>, a Associação nasce para representar
            quem faz a gestão ambiental acontecer na região dos Campos Gerais.
          </p>
          <ul class="valores" aria-label="Nossos valores">
            {valores.map((v) => <li>{v}</li>)}
          </ul>
        </div>
        <div class="sobre-cartoes">
          <article class="cartao reveal" style="--i:3">
            <h3>Missão</h3>
            <p>
              Representar, fortalecer e valorizar a classe profissional, promovendo excelência
              técnica, ética e profissionalismo, ampliando a visão sobre oportunidades. Atuar como
              facilitadores, desmistificando processos e potencializando o desenvolvimento das
              empresas e dos profissionais.
            </p>
          </article>
          <article class="cartao cartao-rio reveal" style="--i:4">
            <h3>Visão</h3>
            <p>
              Ser referência nos Campos Gerais em consultoria e gestão ambiental, reconhecida pela
              excelência técnica dos seus associados e pela contribuição ao desenvolvimento
              sustentável da região.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== EMPRESAS ===================== -->
  <section id="empresas" class="empresas" aria-labelledby="titulo-empresas">
    <div class="container">
      <p class="eyebrow reveal" style="--i:0">Empresas Associadas</p>
      <h2 id="titulo-empresas" class="section-title reveal" style="--i:1">Quem faz parte</h2>
      <p class="empresas-nota reveal" style="--i:2">
        Cada nome abre o portfólio da empresa em PDF, em uma nova aba.
      </p>
      <ol class="lista-empresas">
        {
          empresas.map((empresa, i) => (
            <li class="reveal reveal-x" style={`--i:${i + 3}`}>
              <a
                class="empresa"
                href={empresa.data.portfolio}
                target="_blank"
                rel="noopener"
                aria-label={`${empresa.data.nome} — ver portfólio em PDF (abre em nova aba)`}
              >
                <span class="empresa-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="empresa-info">
                  <span class="empresa-nome">{empresa.data.nome}</span>
                  {empresa.data.descricao && <span class="empresa-desc">{empresa.data.descricao}</span>}
                </span>
                <span class="empresa-cta" aria-hidden="true">Ver portfólio <span class="seta">→</span></span>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ===================== ATUAÇÃO ===================== -->
  <section id="atuacao" class="atuacao" aria-labelledby="titulo-atuacao">
    <div class="container">
      <p class="eyebrow reveal" style="--i:0">Atuação e objetivos</p>
      <h2 id="titulo-atuacao" class="section-title reveal" style="--i:1">O que a Associação oferece aos associados</h2>
      <ul class="lista-atuacao">
        {
          atuacao.map((item, i) => (
            <li class="reveal" style={`--i:${i + 2}`}>
              <h3>{item.titulo}</h3>
              <p>{item.texto}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ===================== EVENTOS ===================== -->
  <section id="eventos" aria-labelledby="titulo-eventos">
    <div class="container">
      <p class="eyebrow reveal" style="--i:0">Eventos</p>
      <h2 id="titulo-eventos" class="section-title reveal" style="--i:1">Agenda e memórias da Associação</h2>
      {
        eventos.length === 0 ? (
          <p>Em breve divulgaremos nossos próximos eventos.</p>
        ) : (
          <ul class="grade-eventos">
            {eventos.map((evento, i) => (
              <li class="reveal" style={`--i:${i + 2}`}>
                <a class="evento-cartao" href={`/eventos/${evento.id}/`}>
                  <div class="evento-foto">
                    {evento.data.fotos.length > 0 ? (
                      <Image
                        src={evento.data.fotos[0]}
                        alt=""
                        width={640}
                        height={420}
                        loading="lazy"
                      />
                    ) : (
                      <div class="evento-sem-foto" aria-hidden="true">✦</div>
                    )}
                  </div>
                  <div class="evento-corpo">
                    <time datetime={evento.data.data.toISOString().slice(0, 10)}>
                      {formatarData(evento.data.data)}
                    </time>
                    <h3>{evento.data.titulo}</h3>
                    <p>{resumo(evento.body)}</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>

  <!-- ===================== CONTATO ===================== -->
  <section id="contato" class="contato" aria-labelledby="titulo-contato">
    <div class="container">
      <p class="eyebrow eyebrow-claro reveal" style="--i:0">Contato</p>
      <h2 id="titulo-contato" class="section-title reveal" style="--i:1">Vamos conversar?</h2>
      <p class="contato-texto reveal" style="--i:2">
        Quer associar sua empresa, propor uma parceria ou saber mais sobre a Associação?
        Escreva para a gente:
      </p>
      <a class="contato-email reveal" style="--i:3" href="mailto:associacaodosconsultorespg@gmail.com">
        associacaodosconsultorespg@gmail.com
      </a>
      <p class="contato-local reveal" style="--i:4">Ponta Grossa – PR · na sede da ACIPG</p>
    </div>
  </section>
</Base>

<script is:inline>
  // Carrega o widget do Netlify Identity apenas quando a URL traz um token
  // (convite, recuperação de senha etc.), redirecionando ao /admin.
  if (/(invite_token|recovery_token|confirmation_token|email_change_token)/.test(location.hash)) {
    var s = document.createElement('script');
    s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
    s.onload = function () {
      window.netlifyIdentity.on('login', function () {
        document.location.href = '/admin/';
      });
      window.netlifyIdentity.init();
    };
    document.head.appendChild(s);
  }
</script>

<style>
  /* ---------- Hero ---------- */
  .hero {
    padding-block: clamp(3rem, 8vw, 6.5rem) clamp(1rem, 3vw, 2rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    margin-block: 1.25rem 1.5rem;
    letter-spacing: -0.01em;
  }

  .hero h1 em {
    font-style: italic;
    font-variation-settings: 'opsz' 144;
    color: var(--verde-700);
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--ink-soft);
    max-width: 34rem;
    margin-bottom: 2rem;
  }

  .hero-acoes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero-logo :global(img) {
    border-radius: 50%;
    box-shadow: 0 24px 60px -24px rgba(23, 64, 42, 0.45);
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-logo {
      order: -1;
      max-width: 13rem;
    }
  }

  /* ---------- Sobre ---------- */
  .sobre-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    margin-top: 1rem;
  }

  .sobre-texto p + p {
    margin-top: 1rem;
  }

  .valores {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
  }

  .valores li {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--verde-900);
    background: var(--paper-2);
    border: 1px solid var(--verde-300);
    border-radius: 999px;
    padding: 0.45rem 1rem;
  }

  .sobre-cartoes {
    display: grid;
    gap: 1.25rem;
    align-content: start;
  }

  .cartao {
    background: var(--verde-900);
    color: var(--paper);
    border-radius: 1.25rem;
    padding: 1.75rem;
  }

  .cartao h3 {
    color: var(--verde-300);
    font-size: 1.35rem;
    margin-bottom: 0.6rem;
  }

  .cartao p {
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .cartao-rio {
    background: var(--paper-2);
    color: var(--ink);
    border: 1px solid var(--rio-400);
  }

  .cartao-rio h3 {
    color: var(--rio-600);
  }

  @media (max-width: 820px) {
    .sobre-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Empresas: vitrine tipográfica ---------- */
  .empresas {
    background: var(--verde-950);
  }

  .empresas .eyebrow {
    color: var(--verde-300);
  }

  .empresas .eyebrow::before {
    background: var(--verde-300);
  }

  .empresas .section-title {
    color: var(--paper);
  }

  .empresas-nota {
    color: var(--verde-300);
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
  }

  .lista-empresas {
    list-style: none;
    border-top: 1px solid rgba(246, 243, 232, 0.18);
  }

  .empresa {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: clamp(1.5rem, 4vw, 2.4rem) 0;
    border-bottom: 1px solid rgba(246, 243, 232, 0.18);
    text-decoration: none;
    transition: padding-left 0.25s ease;
  }

  .empresa-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    color: var(--verde-500);
  }

  .empresa-info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .empresa-nome {
    font-family: var(--font-display);
    font-weight: 520;
    font-size: clamp(1.5rem, 4.2vw, 2.6rem);
    line-height: 1.12;
    color: var(--paper);
    transition: color 0.25s ease;
    text-wrap: balance;
  }

  .empresa-desc {
    font-size: 0.95rem;
    color: rgba(246, 243, 232, 0.65);
    max-width: 38rem;
  }

  .empresa-cta {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rio-400);
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-6px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .empresa-cta .seta {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .empresa:hover,
  .empresa:focus-visible {
    padding-left: 0.75rem;
  }

  .empresa:hover .empresa-nome,
  .empresa:focus-visible .empresa-nome {
    color: var(--rio-400);
  }

  .empresa:hover .empresa-cta,
  .empresa:focus-visible .empresa-cta {
    opacity: 1;
    transform: translateX(0);
  }

  .empresa:hover .empresa-cta .seta {
    transform: translateX(4px);
  }

  /* No toque/mobile o indicador fica sempre visível */
  @media (hover: none), (max-width: 640px) {
    .empresa {
      grid-template-columns: auto 1fr;
    }
    .empresa-cta {
      grid-column: 2;
      opacity: 1;
      transform: none;
    }
  }

  /* ---------- Atuação ---------- */
  .lista-atuacao {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .lista-atuacao li {
    background: #fffdf5;
    border: 1px solid var(--paper-2);
    border-radius: 1rem;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .lista-atuacao li::before {
    content: '❧';
    display: block;
    color: var(--verde-500);
    font-size: 1.4rem;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .lista-atuacao h3 {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
  }

  .lista-atuacao p {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  /* ---------- Eventos ---------- */
  .grade-eventos {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1.75rem;
    margin-top: 1.5rem;
  }

  .evento-cartao {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #fffdf5;
    border: 1px solid var(--paper-2);
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .evento-cartao:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -24px rgba(23, 64, 42, 0.4);
  }

  .evento-foto :global(img) {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .evento-sem-foto {
    aspect-ratio: 3 / 2;
    display: grid;
    place-items: center;
    font-size: 2rem;
    color: var(--verde-300);
    background: var(--paper-2);
  }

  .evento-corpo {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .evento-corpo time {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rio-600);
  }

  .evento-corpo h3 {
    font-size: 1.35rem;
  }

  .evento-corpo p {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  /* ---------- Contato ---------- */
  .contato {
    background: var(--verde-900);
    text-align: center;
  }

  .contato .eyebrow {
    color: var(--verde-300);
  }

  .contato .eyebrow::before {
    background: var(--verde-300);
  }

  .contato .section-title,
  .contato-texto {
    color: var(--paper);
  }

  .contato-texto {
    max-width: 34rem;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .contato-email {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 3.4vw, 2.1rem);
    color: var(--rio-400);
    text-decoration-color: var(--rio-600);
    word-break: break-all;
  }

  .contato-email:hover {
    color: var(--rio-200);
  }

  .contato-local {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--verde-300);
  }

  .eyebrow.eyebrow-claro {
    justify-content: center;
  }

  .contato .eyebrow {
    justify-content: center;
  }
</style>

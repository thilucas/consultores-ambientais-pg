---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const eventos = await getCollection('eventos');
  return eventos.map((evento) => ({ params: { id: evento.id }, props: { evento } }));
}

const { evento } = Astro.props;
const { Content } = await render(evento);

const dataFormatada = evento.data.data.toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});

// Versões grandes das fotos para o lightbox
const fotosGrandes = await Promise.all(
  evento.data.fotos.map((foto) => getImage({ src: foto, width: 1600, format: 'webp' }))
);
---

<Base
  title={`${evento.data.titulo} · Associação dos Consultores Ambientais de Ponta Grossa`}
  description={`Evento da Associação dos Consultores Ambientais de Ponta Grossa em ${dataFormatada}: ${evento.data.titulo}.`}
>
  <article class="evento">
    <div class="container">
      <nav aria-label="Trilha de navegação" class="trilha">
        <a href="/#eventos">← Todos os eventos</a>
      </nav>
      <header>
        <time datetime={evento.data.data.toISOString().slice(0, 10)}>{dataFormatada}</time>
        <h1>{evento.data.titulo}</h1>
      </header>
      <div class="corpo">
        <Content />
      </div>

      {
        evento.data.fotos.length > 0 && (
          <section class="galeria" aria-label="Galeria de fotos do evento">
            <h2>Fotos</h2>
            <ul>
              {evento.data.fotos.map((foto, i) => (
                <li>
                  <button
                    type="button"
                    class="abrir-foto"
                    data-indice={i}
                    aria-label={`Ampliar foto ${i + 1} de ${evento.data.fotos.length}`}
                  >
                    <Image src={foto} alt={`Foto ${i + 1} do evento ${evento.data.titulo}`} width={640} height={480} loading="lazy" />
                  </button>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </article>

  {
    evento.data.fotos.length > 0 && (
      <dialog id="lightbox" aria-label="Foto ampliada">
        <button type="button" class="lb-fechar" aria-label="Fechar">✕</button>
        <button type="button" class="lb-ant" aria-label="Foto anterior">←</button>
        <img id="lb-img" src={fotosGrandes[0].src} alt="" />
        <button type="button" class="lb-prox" aria-label="Próxima foto">→</button>
        <p class="lb-contador" aria-live="polite"></p>
      </dialog>
    )
  }

  <script is:inline define:vars={{ fontes: fotosGrandes.map((f) => f.src), titulo: evento.data.titulo }}>
    const dialogo = document.getElementById('lightbox');
    if (dialogo) {
      const img = document.getElementById('lb-img');
      const contador = dialogo.querySelector('.lb-contador');
      let atual = 0;

      const mostrar = (i) => {
        atual = (i + fontes.length) % fontes.length;
        img.src = fontes[atual];
        img.alt = `Foto ${atual + 1} do evento ${titulo}`;
        contador.textContent = `${atual + 1} / ${fontes.length}`;
      };

      document.querySelectorAll('.abrir-foto').forEach((botao) => {
        botao.addEventListener('click', () => {
          mostrar(Number(botao.dataset.indice));
          dialogo.showModal();
        });
      });

      dialogo.querySelector('.lb-fechar').addEventListener('click', () => dialogo.close());
      dialogo.querySelector('.lb-ant').addEventListener('click', () => mostrar(atual - 1));
      dialogo.querySelector('.lb-prox').addEventListener('click', () => mostrar(atual + 1));

      dialogo.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') mostrar(atual - 1);
        if (e.key === 'ArrowRight') mostrar(atual + 1);
      });

      // Clique no fundo fecha
      dialogo.addEventListener('click', (e) => {
        if (e.target === dialogo) dialogo.close();
      });
    }
  </script>
</Base>

<style>
  .evento {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .trilha {
    margin-bottom: 2rem;
  }

  .trilha a {
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }

  .trilha a:hover {
    text-decoration: underline;
  }

  header time {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rio-600);
  }

  header h1 {
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    margin-block: 0.75rem 1.75rem;
    max-width: 20ch;
  }

  .corpo {
    max-width: 44rem;
    font-size: 1.08rem;
  }

  .corpo :global(p + p) {
    margin-top: 1rem;
  }

  .corpo :global(ul),
  .corpo :global(ol) {
    padding-left: 1.5rem;
    margin-block: 1rem;
  }

  .galeria {
    margin-top: 3.5rem;
    padding-block: 0;
  }

  .galeria h2 {
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .galeria ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 1rem;
  }

  .abrir-foto {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    border-radius: 0.9rem;
    overflow: hidden;
    cursor: zoom-in;
    background: var(--paper-2);
    transition: transform 0.2s ease;
  }

  .abrir-foto:hover {
    transform: scale(1.02);
  }

  .abrir-foto :global(img) {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  /* ---------- Lightbox ---------- */
  dialog {
    border: none;
    background: transparent;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    display: none;
    place-items: center;
  }

  dialog[open] {
    display: grid;
  }

  dialog::backdrop {
    background: rgba(18, 46, 30, 0.92);
  }

  dialog img {
    max-width: min(92vw, 70rem);
    max-height: 82vh;
    object-fit: contain;
    border-radius: 0.5rem;
    grid-area: 1 / 1;
  }

  dialog button {
    grid-area: 1 / 1;
    z-index: 2;
    width: 2.9rem;
    height: 2.9rem;
    border: none;
    border-radius: 50%;
    background: rgba(246, 243, 232, 0.92);
    color: var(--verde-950);
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
  }

  dialog button:hover {
    background: var(--paper);
  }

  .lb-fechar {
    place-self: start end;
    margin: 1rem;
  }

  .lb-ant {
    place-self: center start;
    margin-left: 0.75rem;
  }

  .lb-prox {
    place-self: center end;
    margin-right: 0.75rem;
  }

  .lb-contador {
    grid-area: 1 / 1;
    place-self: end center;
    margin-bottom: 1rem;
    color: var(--paper);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
  }
</style>
